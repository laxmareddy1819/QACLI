{
  "name": "qabot",
  "version": "0.1.0",
  "description": "AI-powered interactive CLI for test automation",
  "type": "module",
  "bin": {
    "qabot": "./bin/qabot.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "build:ui": "cd ui-app && npx vite build",
    "build:all": "pnpm run build:ui && tsup",
    "dev": "tsup --watch",
    "dev:ui": "cd ui-app && npx vite --port 3701",
    "start": "node bin/qabot.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "clean": "rimraf dist"
  },
  "keywords": [
    "test-automation",
    "ai",
    "llm",
    "playwright",
    "selenium",
    "cypress",
    "cli",
    "interactive",
    "sdet"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.21.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "cli-highlight": "^2.1.0",
    "conf": "^13.0.0",
    "csv-parse": "^6.1.0",
    "debug": "^4.3.0",
    "dotenv": "^17.2.4",
    "express": "^4.21.0",
    "glob": "^11.0.0",
    "mammoth": "^1.11.0",
    "marked": "^14.0.0",
    "marked-terminal": "^7.1.0",
    "multer": "^2.0.2",
    "open": "^10.1.0",
    "openai": "^4.60.0",
    "ora": "^8.1.0",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.48.0",
    "simple-git": "^3.32.2",
    "strip-ansi": "^7.1.0",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/debug": "^4.1.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.5.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
