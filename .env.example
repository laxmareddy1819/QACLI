# ============================================================
# qabot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# You only need to configure the provider(s) you plan to use.
# At minimum, set one API key OR use a local LLM (Ollama/LM Studio).
# ============================================================

# ── Cloud LLM Provider API Keys ────────────────────────────
# Get your keys from:
#   OpenAI:    https://platform.openai.com/api-keys
#   Anthropic: https://console.anthropic.com/settings/keys
#   Google:    https://aistudio.google.com/apikey
#   xAI:       https://console.x.ai/

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# ── Cloud LLM Models ───────────────────────────────────────
# Override the default model for each cloud provider.
# If not set, qabot uses sensible defaults shown below.
#
# OpenAI models:     gpt-4o (default), gpt-4o-mini, gpt-4-turbo, o1, o1-mini, o3-mini
# Anthropic models:  claude-sonnet-4-20250514 (default), claude-opus-4-20250514, claude-3-5-haiku-20241022
# Google models:     gemini-2.0-flash (default), gemini-2.5-pro, gemini-2.0-flash-lite
# xAI models:        grok-2-latest (default), grok-3, grok-3-mini

OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GOOGLE_MODEL=gemini-2.0-flash
XAI_MODEL=grok-2-latest

# ── Local LLM Settings ─────────────────────────────────────
# No API key needed! Just install and run Ollama or LM Studio.
#
# Ollama:     https://ollama.com  (run: ollama serve)
# LM Studio:  https://lmstudio.ai (start local server from UI)

# Base URLs (defaults shown - change if running on different port/host)
OLLAMA_BASE_URL=http://localhost:11434/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Local LLM Models
# Ollama:    llama3 (default), codellama, mistral, deepseek-coder, phi3, qwen2.5-coder
#            Run "ollama list" to see your installed models
#            Run "ollama pull <model>" to download a new model
# LM Studio: default (default) - uses whatever model is loaded in LM Studio UI
#            Or specify the exact model name from LM Studio

OLLAMA_MODEL=llama3
LMSTUDIO_MODEL=default

# ── qabot Default Settings ──────────────────────────────────
# Which provider to use by default when qabot starts
# Options: openai, anthropic, google, xai, ollama, lmstudio
QABOT_DEFAULT_PROVIDER=openai

# Override the default model (takes priority over provider-specific model above)
# Leave empty to use the provider-specific model setting
QABOT_DEFAULT_MODEL=

# Maximum tool call iterations per request (default: 30, max: 100)
# Increase if you get "max tool iterations" errors during complex browser flows
QABOT_MAX_TOOL_ITERATIONS=30

# ── Quick Start Examples ────────────────────────────────────
#
# Use OpenAI GPT-4o (most common):
#   OPENAI_API_KEY=sk-...
#   QABOT_DEFAULT_PROVIDER=openai
#
# Use Anthropic Claude:
#   ANTHROPIC_API_KEY=sk-ant-...
#   QABOT_DEFAULT_PROVIDER=anthropic
#
# Use local Ollama (free, no API key):
#   1. Install: https://ollama.com
#   2. Run: ollama pull llama3 && ollama serve
#   3. Set: QABOT_DEFAULT_PROVIDER=ollama
#
# Use local LM Studio (free, no API key):
#   1. Install: https://lmstudio.ai
#   2. Load a model and start the local server
#   3. Set: QABOT_DEFAULT_PROVIDER=lmstudio
#
# You can also switch providers/models at runtime:
#   /provider ollama
#   /model codellama
# ============================================================
